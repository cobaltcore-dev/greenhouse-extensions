{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "baseBranchPatterns": ["playground"],
  "assigneesFromCodeOwners": true,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "packageRules": [
    {
      "matchFileNames": ["**/plugindefinition.yaml"],
      "matchManagers": ["custom.regex"],
      "groupName": "{{parentDir}} helm chart"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": ["Update spec.version in plugindefinition.yaml"],
      "managerFilePatterns": ["/(^|/)plugindefinition\\.yaml$/"],
      "matchStrings": [
        "spec:\\s+version:\\s+(?<currentValue>[^\\s]+)\\s+displayName:[^\\n]+\\s+description:[^\\n]+(?:[^\\n]*\\n)*?\\s+helmChart:\\s+name:\\s+(?<depName>[^\\s]+)\\s+repository:\\s+oci://(?<registryUrl>[^/]+)/(?<path>.+?)\\s+version:"
      ],
      "datasourceTemplate": "docker",
      "registryUrlTemplate": "https://{{{registryUrl}}}",
      "packageNameTemplate": "{{{path}}}/{{{depName}}}",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": ["Update helmChart.version in plugindefinition.yaml"],
      "managerFilePatterns": ["/(^|/)plugindefinition\\.yaml$/"],
      "matchStrings": [
        "helmChart:\\s+name:\\s+(?<depName>[^\\s]+)\\s+repository:\\s+oci://(?<registryUrl>[^/]+)/(?<path>.+?)\\s+version:\\s+(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker",
      "registryUrlTemplate": "https://{{{registryUrl}}}",
      "packageNameTemplate": "{{{path}}}/{{{depName}}}",
      "versioningTemplate": "loose"
    }
  ]
}